GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
AI_PROVIDER_PRIORITY=gemini,openai

ENV=development
DATABASE_URL=sqlite+aiosqlite:///./data/agent.db
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://llm-web-testing-agent.vercel.app
BROWSER_HEADLESS=true
DEFAULT_BROWSER=chromium
PRODUCTION_TIMEOUT_MS=30000
ACTION_RETRIES=2
EVIDENCE_SCREENSHOTS=true
RATE_LIMIT_PER_MINUTE=60
SECRET_KEY=replace-with-a-long-random-secret
